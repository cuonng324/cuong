<!DOCTYPE html>
<html>
<head>
  <title>Happy 20/10</title>
  <style>
    body {
      background-color: #fff0f5;
      text-align: center;
      font-family: 'Arial', sans-serif;
    }

    .heart {
      color: red;
      font-size: 100px;
      animation: beat 1s infinite;
    }

    @keyframes beat {
      0% { transform: scale(1); }
      50% { transform: scale(1.2); }
      100% { transform: scale(1); }
    }

    .msg {
      font-size: 24px;
      color: #d6336c;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <div class="heart">❤️</div>
  <div class="msg">Chúc em 20/10 tràn ngập yêu thương! 💐<br>Yêu em nhiều lắm! 💖</div>
</body>
</html>
